# ─── Stage 1: Install dependencies ───
FROM node:20-slim AS deps

WORKDIR /app

# Copy root workspace config and lockfile
COPY package.json package-lock.json ./

# Copy all workspace package.json files (web depends on shared types at build time)
COPY packages/shared/package.json packages/shared/
COPY packages/workflow-engine/package.json packages/workflow-engine/
COPY packages/api-core/package.json packages/api-core/
COPY packages/api-integrations/package.json packages/api-integrations/
COPY apps/web/package.json apps/web/

# Install all dependencies (including dev for Vite build)
RUN npm ci --ignore-scripts

# ─── Stage 2: Build ───
FROM deps AS build

WORKDIR /app

# Copy tsconfig and source for packages (needed for type resolution)
COPY tsconfig.base.json ./
COPY packages/shared/tsconfig.json packages/shared/
COPY packages/shared/src/ packages/shared/src/

# Build shared package (web imports from it)
RUN npm --workspace packages/shared run build

# Copy web app source
COPY apps/web/ apps/web/

# Build argument for API URL (empty = relative paths via nginx proxy)
ARG VITE_API_BASE_URL=""
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

# Build the frontend
RUN npm --workspace apps/web run build

# ─── Stage 3: Nginx ───
FROM nginx:1.27-alpine AS production

# Remove default config
RUN rm /etc/nginx/conf.d/default.conf

# Copy nginx template (envsubst processes only API_UPSTREAM at startup)
COPY nginx.web.conf /etc/nginx/templates/default.conf.template
ENV NGINX_ENVSUBST_FILTER=API_UPSTREAM

# Copy built static files
COPY --from=build /app/apps/web/dist/ /usr/share/nginx/html/

# Non-root user
RUN chown -R nginx:nginx /usr/share/nginx/html && \
    chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    touch /var/run/nginx.pid && \
    chown -R nginx:nginx /var/run/nginx.pid

EXPOSE 8080

CMD ["nginx", "-g", "daemon off;"]
