# =============================================================================
# IntelliRAG — Environment Variables
# Copy to .env and fill in values for your environment.
# =============================================================================

# --- Server ---
API_PORT=3001
API_HOST=0.0.0.0

# --- Database (PostgreSQL + pgvector) ---
DATABASE_URL=postgres://intellirag:intellirag@localhost:5432/intellirag
DATABASE_SSL=false
DB_POOL_MAX=8
DB_SLOW_QUERY_MS=500

# --- Authentication ---
# REQUIRED: Generate with: openssl rand -base64 32
JWT_SECRET=intellirag-dev-secret-DO-NOT-USE-IN-PRODUCTION
JWT_ENFORCE_JTI=true

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Storage ---
# Cloud Run currently uses a shared uploads mount; local default remains filesystem.
STORAGE_PROVIDER=local
STORAGE_BASE_DIR=./uploads
STORAGE_MAX_FILE_BYTES=52428800
# When STORAGE_PROVIDER=gcs
# GCS_BUCKET=police-cases-kb-uploads-809677427844
# GCS_PROJECT_ID=policing-apps
# Allow local storage only when a shared mount is intentionally provided
# ALLOW_LOCAL_STORAGE_SHARED_MOUNT=true

# --- Ollama (local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3:35b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_EMBEDDING_DIMENSIONS=768

# --- OpenRouter / Qwen (Cloud default answer model) ---
# OPENROUTER_API_KEY=sk-or-...

# --- OpenAI (cloud fallback / regenerate / embeddings / worker metadata) ---
# API accepts OPENAI_API_KEY; worker accepts OPENAI_API_KEY or OPEN_AI_API_KEY.
# OPENAI_API_KEY=sk-...
# OPEN_AI_API_KEY=sk-...
# OPEN_AI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic Claude (optional) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Google Gemini (worker KG extraction) ---
# GEMINI_API_KEY=AIzaSy...
# GEMINI_MODEL=gemini-2.5-flash
# KG_LLM_PROVIDER=gemini
# KG_MODEL_ID=gemini-2.5-flash

# --- Google Document AI (worker OCR) ---
# These are the live variable names used by the deployed worker service.
# DOCUMENT_AI_PROJECT_ID=wealth-report
# DOCUMENT_AI_LOCATION=eu
# DOCUMENT_AI_PROCESSOR_ID=70b690b94894b43
# DOCUMENT_AI_CREDENTIALS_PATH=/var/secrets/document-ai/wealth-report-sa.json

# --- OCR / Parsing ---
# OCR_NATIVE_CONFIDENCE_THRESHOLD=0.75
# OCR_REVIEW_THRESHOLD=0.65
# OCR_PARALLEL_PAGES=10
# OCR_CONFIDENCE_THRESHOLD=0.7
# OCR_PAGE_TIMEOUT_S=120

# --- Python Worker ---
WORKER_POLL_INTERVAL_S=2
WORKER_BATCH_SIZE=5
WORKER_MAX_RETRIES=3
WORKER_POLLER_THREADS=3

# --- Observability ---
OTEL_ENABLED=false
OTEL_SERVICE_NAME=intellirag-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# --- Feature Flags ---
FEATURE_FLAG_CACHE_TTL_MS=15000

# --- Frontend (build-time) ---
# VITE_API_BASE_URL=http://localhost:3001
